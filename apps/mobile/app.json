{
  "expo": {
    "name": "Enzyme",
    "slug": "enzyme",
    "version": "0.1.0",
    "scheme": "enzyme",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "im.enzyme.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "im.enzyme.mobile"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4F46E5",
          "defaultChannel": {
            "name": "Messages",
            "description": "New message notifications",
            "importance": 4,
            "vibrationPattern": [0, 250, 250, 250],
            "sound": "default"
          }
        }
      ]
    ]
  }
}
